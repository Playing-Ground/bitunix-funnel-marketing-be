APP_NAME="Bitunix MarTech"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bitunix_martech
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@bitunixads.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# MarTech dashboard — internal API-key gate
# =============================================================================
# Generate with: php -r "echo bin2hex(random_bytes(32));"
DASHBOARD_API_KEY=

# =============================================================================
# Google service account (GA4 BigQuery + Search Console)
# =============================================================================
# Absolute path to the service account JSON for `ga4-api-access@ga4-bitunix-bigquery.iam.gserviceaccount.com`
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/storage/credentials/ga4-sa.json
GA4_BIGQUERY_PROJECT_ID=ga4-bitunix-bigquery
GA4_BIGQUERY_DATASET=analytics_476333519
GA4_PROPERTY_ID=476333519
GSC_SITE_URL=https://www.bitunix.com/

# =============================================================================
# Bitunix Partner Portal (private API — JWT rotated manually via /settings)
# =============================================================================
BITUNIX_PARTNER_BASE_URL=https://partners.bitunix.com
BITUNIX_PARTNER_TIMEOUT=30

# =============================================================================
# Horizon dashboard access (IP whitelist for no-login gate)
# =============================================================================
HORIZON_ALLOWED_IPS=127.0.0.1
